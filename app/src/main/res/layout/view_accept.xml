<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#F0F8FF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Profile Banner -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/app_bg_wave"
                android:paddingBottom="16dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/photo1"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginTop="24dp"
                    android:src="@drawable/camera_1"
                    app:civ_border_width="3dp"
                    app:civ_border_color="#FFFFFF"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Fallback Hidden Image -->
                <ImageView
                    android:id="@+id/img"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginTop="24dp"
                    android:src="@drawable/defaultpic"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="1"
                    android:shrinkColumns="1">

                    <!-- Order ID -->
                    <TableRow android:paddingVertical="8dp">
                        <TextView android:text="Order ID:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/odrId" android:text="#---" android:fontFamily="@font/avn_bold" android:textColor="#0072ff" android:textSize="16sp" />
                    </TableRow>

                    <!-- Tech Name -->
                    <TableRow android:paddingVertical="8dp">
                        <TextView android:text="Technician:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/cname" android:text="-" android:fontFamily="@font/avn" android:textColor="#333333" android:textSize="16sp" />
                    </TableRow>

                    <!-- Mobile -->
                    <TableRow android:paddingVertical="8dp">
                        <TextView android:text="Mobile:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/cmob" android:text="-" android:fontFamily="@font/avn" android:textColor="#333333" android:textSize="16sp" />
                    </TableRow>

                    <!-- Address (Hidden originally) -->
                    <TableRow android:paddingVertical="8dp" android:visibility="gone">
                        <TextView android:text="Address:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/cadres" android:text="-" android:fontFamily="@font/avn" android:textColor="#333333" android:textSize="16sp" />
                    </TableRow>

                    <View android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="12dp"/>

                    <!-- Service Name -->
                    <TableRow android:paddingVertical="8dp">
                        <TextView android:text="Service:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/servicename" android:text="-" android:fontFamily="@font/avn_bold" android:textColor="#333333" android:textSize="16sp" />
                    </TableRow>

                    <!-- Pro Area -->
                    <TableRow android:paddingVertical="8dp">
                        <TextView android:text="Prof. Area:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/pro_area_name" android:text="-" android:fontFamily="@font/avn" android:textColor="#333333" android:textSize="16sp" />
                    </TableRow>

                    <!-- Work Detail -->
                    <TableRow android:paddingVertical="8dp">
                        <TextView android:text="Details:" android:fontFamily="@font/avn_bold" android:textColor="#555555" android:textSize="14sp" android:paddingEnd="12dp"/>
                        <TextView android:id="@+id/wrks" android:text="-" android:fontFamily="@font/avn" android:textColor="#333333" android:textSize="16sp" />
                    </TableRow>

                </TableLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="32dp"
                    android:weightSum="2"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingEnd="8dp">
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/cncl"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Cancel"
                            android:textColor="#555555"
                            android:fontFamily="@font/avn_bold"
                            app:cornerRadius="26dp"
                            app:backgroundTint="#E5E7EB"
                            android:textAllCaps="false"
                            app:strokeWidth="0dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/acceptBtn"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Proceed"
                            android:textAllCaps="false"
                            android:fontFamily="@font/avn_bold"
                            app:cornerRadius="26dp"
                            app:backgroundTint="#4CAF50" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>