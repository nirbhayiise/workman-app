<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"

  >
    <include layout="@layout/white_header" android:id="@+id/layhist"/>
    <!-- Expiry Text for email address-->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:padding="10dp"
        android:orientation="vertical">
    <EditText
        android:id="@+id/edit_email_address"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:paddingLeft="10dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/textbox"
        android:layout_marginTop="8dp"
        android:hint="Email Id"

        android:imeOptions="actionNext"
        android:inputType="textEmailAddress" />
    <!-- Expiry Text for credit card number-->
    <EditText
        android:id="@+id/edit_card_number"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/textbox"
        android:paddingLeft="10dp"
        android:layout_alignParentLeft="true"
        android:layout_below="@id/edit_email_address"
        android:layout_marginTop="8dp"
        android:hint="Card number"

        android:imeOptions="actionNext"
        android:inputType="number" />

    <!-- Divider-->
    <View
        android:id="@+id/horizontal_divider"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_centerHorizontal="true" />

    <RelativeLayout
        android:id="@+id/layout_expiry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_below="@id/edit_card_number"
        android:layout_marginTop="8dp"
        android:layout_toLeftOf="@id/horizontal_divider">

        <!-- Expiry Text -->
        <TextView
            android:id="@+id/textview_expiry_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:text="Expire" />

        <!-- EditText for expiry month -->
        <EditText
            android:id="@+id/edit_expiry_month"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:paddingLeft="10dp"
            android:layout_below="@id/textview_expiry_text"
            android:hint="Expire month"
            android:background="@drawable/textbox"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxEms="4"
            android:maxLength="2"
            android:maxLines="1"
            android:padding="8dp" />

        <!-- EditText for expiry year -->
        <EditText
            android:id="@+id/edit_expiry_year"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:paddingLeft="10dp"
            android:layout_marginLeft="10dp"
            android:layout_below="@id/textview_expiry_text"
            android:layout_toRightOf="@id/edit_expiry_month"
            android:hint="yy"
            android:background="@drawable/textbox"
            android:imeOptions="actionNext"
            android:inputType="number"
            android:maxEms="4"
            android:maxLength="2"
            android:maxLines="1"
            android:padding="8dp" />
    </RelativeLayout>

    <!-- layout for cvv -->
    <RelativeLayout
        android:id="@+id/layout_cvv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_below="@id/edit_card_number"
        android:layout_marginTop="8dp"
     >

        <!-- CVV text -->
        <TextView
            android:id="@+id/textview_cvv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="CVV"
            android:paddingLeft="8dp"
            android:text="CVV" />

        <!-- EditText for cvv -->
        <EditText
            android:id="@+id/edit_cvv"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_below="@id/textview_cvv"
            android:imeOptions="actionDone"
            android:paddingLeft="10dp"
            android:inputType="number"
            android:maxLength="3"
            android:hint="CVV"
            android:background="@drawable/textbox"
            android:maxLines="1"
            android:padding="8dp" />
    </RelativeLayout>

    <!--Pay Button -->
    <Button
        android:id="@+id/pay_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/button"
        android:text="pay"
        android:textAllCaps="true"
        android:layout_marginTop="10dp"
        android:textColor="#fff"
        android:textSize="20sp" />
    </LinearLayout>
</LinearLayout>
