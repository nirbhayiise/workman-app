<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg_wave"
    android:orientation="vertical"
  >
    <include layout="@layout/white_header" android:id="@+id/layhist"/>
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="For Support Contact Us"
            android:fontFamily="@font/avn_bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="20dp"
            android:textSize="22dp"/>
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:orientation="horizontal">

            <ImageView

                android:layout_width="30dp"
                android:layout_height="30dp"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/avn"
                android:text="G3 Integrated Resources Services Ltd."
                android:layout_marginLeft="10dp"
                android:textSize="20dp"/>
        </LinearLayout>
<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/mail"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:src="@drawable/about_icon_email"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/avn"
        android:text="info247workman@gmail.com"
        android:layout_marginLeft="10dp"
        android:textSize="20dp"/>
</LinearLayout>
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/pho"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/phone_contact"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:text="GSM: +2348141240001"
            android:fontFamily="@font/avn"
            android:textSize="20dp"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="horizontal">
        <ImageView

            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/addres"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/avn"
            android:layout_marginLeft="10dp"
            android:text="# 2B Mini-Ezekwe Street Off Okporo Rumuogba Port Harcount Rivers State"
            android:textSize="20dp"/>
    </LinearLayout>

    </LinearLayout>
</LinearLayout>