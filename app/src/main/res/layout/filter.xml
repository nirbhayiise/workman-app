<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

android:background="@color/bg"
    tools:context=".MainActivity">

<include layout="@layout/white_header" android:id="@+id/hdrlay"
    />
<LinearLayout
    android:layout_width="fill_parent"
    android:orientation="vertical"
    android:gravity="center|top"
    android:padding="10dp"
    android:layout_below="@+id/hdrlay"
    android:layout_height="fill_parent">
    <LinearLayout
        android:layout_width="fill_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2"

        android:layout_height="wrap_content">
<LinearLayout
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_weight="0.4">
    <EditText
        android:layout_width="fill_parent"
        android:layout_height="34dp"
        android:fontFamily="@font/avn"
        android:textSize="12dp"
        android:paddingRight="10dp"
        android:drawableRight="@drawable/srch_ic"
        android:hint="Location"

        android:paddingLeft="10dp"
        android:background="@drawable/circletxt"/>
</LinearLayout>
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1.6">
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:layout_marginLeft="4dp"
                android:orientation="vertical"
                android:background="@drawable/location_button">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/loca_ic"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10dp"
                    android:fontFamily="@font/avn"

                    android:text="Nearby"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="fill_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="Rating"
            android:fontFamily="@font/avn"
            android:textColor="@color/blackColor"
            android:gravity="center|left"
            android:textSize="12dp"/>
        <LinearLayout
            android:layout_width="fill_parent"
            android:orientation="horizontal"
            android:weightSum="5"
            android:layout_marginTop="10dp"
            android:layout_height="wrap_content">
            <LinearLayout
                android:id="@+id/s1"
                android:layout_width="fill_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginLeft="10dp"
                android:gravity="center"
                android:layout_height="30dp"
               >
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star_light"/>
                <TextView
                    android:id="@+id/st1"
                    android:layout_width="wrap_content"
                    android:textSize="10dp"
                    android:fontFamily="@font/avn"
                    android:layout_marginLeft="6dp"
                    android:layout_height="wrap_content"
                    android:text="1"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/s2"
                android:layout_width="fill_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginLeft="10dp"
                android:gravity="center"
                android:layout_height="30dp"
                >
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star_light"/>
                <TextView
                    android:id="@+id/st2"
                    android:layout_width="wrap_content"
                    android:textSize="10dp"
                    android:fontFamily="@font/avn"
                    android:layout_marginLeft="6dp"
                    android:layout_height="wrap_content"
                    android:text="2"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/s3"
                android:layout_width="fill_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginLeft="10dp"
                android:gravity="center"
                android:layout_height="30dp"
              >
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star_light"/>
                <TextView
                    android:id="@+id/st3"
                    android:layout_width="wrap_content"
                    android:textSize="10dp"
                    android:fontFamily="@font/avn"
                    android:layout_marginLeft="6dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/whitecolor"
                    android:text="3"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/s4"
                android:layout_width="fill_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginLeft="10dp"
                android:gravity="center"
                android:layout_height="30dp"
              >
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star_light"/>
                <TextView
                    android:id="@+id/st4"
                    android:layout_width="wrap_content"
                    android:textSize="10dp"
                    android:fontFamily="@font/avn"
                    android:layout_marginLeft="6dp"
                    android:layout_height="wrap_content"
                    android:text="4"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/s5"
                android:layout_width="fill_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginLeft="10dp"
                android:gravity="center"
                android:layout_height="30dp"
                >
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star_light"/>
                <TextView
                    android:id="@+id/st5"
                    android:layout_width="wrap_content"
                    android:textSize="10dp"
                    android:fontFamily="@font/avn"
                    android:layout_marginLeft="6dp"
                    android:layout_height="wrap_content"
                    android:text="5"/>
            </LinearLayout>
        </LinearLayout>
        <View
            android:layout_width="fill_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="@color/lineColor"/>
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp">
            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blackColor"
                android:fontFamily="@font/avn"
                android:textSize="12dp"
                android:text="Select Type"/>
            <org.angmarch.views.NiceSpinner
                android:id="@+id/nice_spinner"
                android:layout_width="fill_parent"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/avn"
                android:layout_height="40dp"
                android:layout_margin="5dp"/>
            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blackColor"
                android:textSize="12dp"
                android:fontFamily="@font/avn"
                android:text="Qty"/>
            <EditText
                android:layout_width="fill_parent"
                android:layout_height="38dp"
                android:layout_marginTop="10dp"
                android:hint="Qty of Selected Type"
                android:singleLine="true"
                android:fontFamily="@font/avn"
                android:textSize="12dp"
                android:inputType="number"
                android:paddingLeft="10dp"
                android:background="@drawable/whitetxtbox"
                />
            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blackColor"
                android:textSize="12dp"
                android:fontFamily="@font/avn"
                android:layout_marginTop="10dp"
                android:text="No. Seats Needed"/>
            <EditText
                android:layout_width="fill_parent"
                android:layout_height="38dp"
                android:layout_marginTop="10dp"
                android:hint="No. of Seats"
                android:inputType="number"
                android:singleLine="true"
                android:textSize="12dp"
                android:fontFamily="@font/avn"
                android:paddingLeft="10dp"
                android:background="@drawable/whitetxtbox"
                />
            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/blackColor"
                android:textSize="14dp"
                android:gravity="center"
                android:fontFamily="@font/avn"
                android:layout_marginTop="30dp"


                android:text="Please save your prefrences setting by clicking &apos;APPLY&apos; \n Search on the bases of your prefrences setting."/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
    <Button
        android:id="@+id/applybn"
        android:layout_width="fill_parent"
        android:layout_height="45dp"
        android:layout_marginTop="10dp"
android:layout_alignParentBottom="true"
        android:text="APPLY"
        android:fontFamily="@font/avn_bold"
        android:textColor="@color/whitecolor"
        android:background="@drawable/button"
        />
</RelativeLayout>