<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base subtle gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFFF"
                android:centerColor="#F8FAFC"
                android:endColor="#EFF6FF"
                android:angle="135" />
        </shape>
    </item>
    
    <!-- Subtle abstract shapes to give a premium 'smart' feel -->
    <item android:top="-40dp" android:right="-40dp" android:bottom="80dp" android:left="200dp">
        <shape android:shape="oval">
            <solid android:color="#0A2563EB" />
        </shape>
    </item>
    
    <item android:top="120dp" android:right="200dp" android:bottom="-40dp" android:left="-40dp">
        <shape android:shape="oval">
            <solid android:color="#061E3A8A" />
        </shape>
    </item>
</layer-list>
